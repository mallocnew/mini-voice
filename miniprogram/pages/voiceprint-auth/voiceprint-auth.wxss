page {
  height: 100%;
  background: #0f1419;
  color: #e8ecef;
}

.page {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%, rgba(46, 160, 120, 0.14), transparent 55%),
    #0f1419;
}

.scroll {
  flex: 1;
  height: 0;
}

.doc {
  padding: 40rpx 40rpx 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #f0f4f2;
  margin-bottom: 16rpx;
}

.meta {
  display: block;
  font-size: 22rpx;
  color: rgba(232, 236, 239, 0.4);
  line-height: 1.6;
}

.meta--gap {
  margin-bottom: 36rpx;
}

.h {
  display: block;
  margin-top: 36rpx;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #7dcea0;
}

.p {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(232, 236, 239, 0.78);
  margin-bottom: 12rpx;
}

.spacer {
  height: 40rpx;
}

.footer {
  flex-shrink: 0;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(15, 20, 25, 0.96);
}

.status {
  font-size: 24rpx;
  color: rgba(125, 206, 160, 0.85);
  text-align: center;
  margin-bottom: 4rpx;
}

.btn-primary,
.btn-secondary {
  margin: 0;
  padding: 0;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.btn-primary {
  color: #0f1419;
  background: rgba(125, 206, 160, 0.92);
  border: none;
}

.btn-secondary {
  color: #e8ecef;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.btn-primary::after,
.btn-secondary::after {
  border: none;
}

.btn-hover {
  opacity: 0.8;
}
